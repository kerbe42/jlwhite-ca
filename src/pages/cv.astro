---
import Base from '../layouts/Base.astro';
import { SITE, LINKS, CV } from '../consts';

const skills = [
  { group: 'Cloud security', items: 'Azure / Entra ID, managed identities, Microsoft Graph, identity-based privilege-escalation and account-takeover paths.' },
  { group: 'Web application security', items: 'SSRF (including server-side PDF renderers), stored XSS, and injection testing.' },
  { group: 'AI / LLM security', items: 'Prompt injection, and chaining LLM behaviour with classic web vulnerabilities.' },
  { group: 'Infrastructure', items: 'Proxmox virtualization clusters, pfSense (incl. active/passive HA), Pi-hole, DNS / DNSSEC, Docker / LXC, Linux; running real self-hosted services on real hardware.' },
  { group: 'Making', items: 'FDM and resin 3D printing, hydroponics.' },
];

const writeups = [
  { text: 'Azure / Entra ID privilege escalation: managed identity → Microsoft Graph token → Temporary Access Pass → account takeover', href: '/writeups/tapper-2-azure-tenant' },
  { text: 'Web SSRF through a server-side PDF renderer', href: '/writeups/md2pdf-ssrf' },
  { text: 'AI-pentest room: stored XSS against a reviewer bot, chained with LLM prompt injection', href: '/writeups/medbay-ai-xss-llm' },
  { text: 'AI security: scoping an LLM ops-agent for a Proxmox cluster', href: '/writeups/proxmox-llm-ops-agent' },
  { text: 'Home lab: HA pfSense on Proxmox with dual-WAN failover', href: '/writeups/pfsense-ha-proxmox' },
  { text: 'Home-lab DNS / DNSSEC troubleshooting', href: '/writeups/pihole-dnssec-tcp-fallback' },
];

const hasCredentials =
  CV.certifications.length > 0 || CV.experience.length > 0 || CV.education.length > 0;
---

<Base title="CV" description="Justin White — security practitioner and maker. Skills, writeups, and credentials.">
  <article class="section">
    <div class="wrap wrap-narrow cv">
      <header class="cv-head">
        <h1>Justin White</h1>
        <p class="role">{SITE.tagline}</p>
        <p class="contact">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          {LINKS.github && (<><span>·</span><a href={LINKS.github} rel="me">GitHub</a></>)}
          {LINKS.linkedin && (<><span>·</span><a href={LINKS.linkedin} rel="me">LinkedIn</a></>)}
          {LINKS.tryhackme && (<><span>·</span><a href={LINKS.tryhackme} rel="me">TryHackMe</a></>)}
          {LINKS.credly && (<><span>·</span><a href={LINKS.credly} rel="me">Credly</a></>)}
        </p>
      </header>

      <section>
        <h2>Summary</h2>
        <p>
          I'm accountable for the global security posture of Cooke Inc., one of the largest
          privately held seafood companies in the world — security architecture,
          governance/risk/compliance, and security operations across 17 countries and roughly
          18,000 people, from vessels and hatcheries to processing plants and corporate IT. I came
          up through network engineering and grew into the role that stood up the cybersecurity
          function, so my bias is toward security an always-on operational business can actually
          live with: controls that hold up to the auditors, insurers, and customers who get a say,
          without stalling production. Most of my career has been bringing security maturity to
          sectors that grew up as industrial operations, not software shops. I stay hands-on, too —
          a self-hosted home lab as a live testbed, and security writeups spanning cloud identity,
          web application, and AI/LLM security.
        </p>
      </section>

      <section>
        <h2>What I work with</h2>
        <dl class="skills">
          {skills.map((s) => (
            <div>
              <dt>{s.group}</dt>
              <dd>{s.items}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section>
        <h2>Selected writeups</h2>
        <ul class="links">
          {writeups.map((w) => (<li><a href={w.href}>{w.text}</a></li>))}
        </ul>
      </section>

      <section>
        <h2>Hands-on practice</h2>
        <ul>
          <li>
            <strong>TryHackMe</strong> — offensive-security practice rooms.
            {LINKS.tryhackme && (<> <a href={LINKS.tryhackme} rel="me">View profile →</a></>)}
          </li>
          <li>
            <strong>Home lab</strong> — a four-node Proxmox cluster running an active/passive
            pfSense HA firewall, redundant Pi-hole DNS with DNSSEC, Docker/LXC services, and
            monitoring (Wazuh, Zabbix) as a live environment to test against.
          </li>
          <li>
            <strong>Open source</strong> — public work on
            {LINKS.github ? (<> <a href={LINKS.github} rel="me">GitHub</a>,</>) : (<> GitHub,</>)}
            including this site.
          </li>
        </ul>
      </section>

      {
        hasCredentials && (
          <section>
            <h2>Credentials</h2>
            {CV.certifications.length > 0 && (
              <>
                <h3>Certifications</h3>
                <ul>{CV.certifications.map((c) => (<li>{c}</li>))}</ul>
                {LINKS.credly && (
                  <p class="verify">
                    <a href={LINKS.credly} rel="me">All certifications, verified on Credly →</a>
                  </p>
                )}
              </>
            )}
            {CV.experience.length > 0 && (
              <>
                <h3>Experience</h3>
                <ul class="exp">
                  {CV.experience.map((e) => (
                    <li>
                      <strong>{e.role}</strong>, {e.org} <span class="period">{e.period}</span>
                      {e.note && <div class="note">{e.note}</div>}
                    </li>
                  ))}
                </ul>
              </>
            )}
            {CV.education.length > 0 && (
              <>
                <h3>Education</h3>
                <ul>{CV.education.map((ed) => (<li>{ed}</li>))}</ul>
              </>
            )}
          </section>
        )
      }
    </div>
  </article>
</Base>

<style>
  .cv section { margin-bottom: 2rem; }
  .cv-head { margin-bottom: 2.25rem; }
  .cv-head h1 { margin: 0; }
  .role { color: var(--ink-muted); margin: 0.2rem 0 0.6rem; font-size: 1.1rem; }
  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.95rem;
    margin: 0;
  }
  .contact span { color: var(--ink-faint); }
  .cv h2 {
    font-size: 1.25rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.9rem;
  }
  .cv h3 { font-size: 1rem; margin: 1.2rem 0 0.4rem; }
  .skills { margin: 0; display: grid; gap: 0.85rem; }
  .skills dt { font-weight: 500; font-family: var(--font-serif); font-size: 1.05rem; }
  .skills dd { margin: 0.15rem 0 0; color: var(--ink-muted); }
  .cv ul { padding-left: 1.2rem; margin: 0; }
  .cv li { margin-bottom: 0.5rem; }
  .links a { font-weight: 500; }
  .period { color: var(--ink-faint); font-size: 0.85rem; }
  .note { color: var(--ink-muted); font-size: 0.92rem; margin-top: 0.15rem; }
  .verify { margin-top: 0.6rem; font-size: 0.92rem; }
  .verify a { font-weight: 500; }
</style>

---
import Base from '../layouts/Base.astro';
import { SITE, LINKS, CV } from '../consts';
import certs from '../data/certs.json';

const techDisclaimer = `The technologies listed here are from self-directed work pursued independently (in a personal home lab, in solo open-source projects, through certification study, and in authorized security practice) for my own learning and advancement. They are NOT a representation of any employer's systems, tools, vendors, architecture, or environment, and not technologies I deploy, support, or manage in any professional capacity.`;

const technologies = [
  {
    group: 'Personal projects',
    lead: 'Everything below comes out of four solo projects:',
    projects: [
      { name: 'HouseGRC', desc: 'a GRC platform. Reflex (Python full-stack), SQLAlchemy 2.0, SQLCipher-encrypted SQLite (optional Postgres), Alembic, a FastAPI sub-app, APScheduler, and a REST API.' },
      { name: 'DeepReview / superdeepreview', desc: 'a passive-OSINT engine, with an opt-in, authorized-use-only active edition.' },
      { name: 'GYST', desc: 'a self-hosted household PWA on Reflex + Granian.' },
      { name: 'jlwhite.ca', desc: 'this site, on Astro and Cloudflare Pages.' },
    ],
  },
  {
    group: 'Languages and frameworks',
    lead: 'What I build those with.',
    tags: ['Python', 'Reflex', 'Granian', 'FastAPI', 'Pydantic', 'SQLAlchemy 2.0', 'asyncpg', 'Alembic', 'APScheduler', 'arq (Redis)', 'React', 'Vite', 'TypeScript', 'Tailwind', 'TanStack Query', 'Recharts', 'Astro', 'sharp', 'service workers', 'VAPID push'],
  },
  {
    group: 'Cloud and identity',
    lead: 'Built into my own apps and certification study, not an operated environment.',
    tags: ['SAML 2.0', 'OIDC/OAuth SSO', 'SCIM 2.0', 'group RBAC', 'MFA (TOTP)', 'WebAuthn/passkeys', 'AWS (boto3)', 'GitHub connector', 'Okta connector', 'S3 / SFTP / WebDAV', 'Cloudflare Pages', 'DNS/DNSSEC', 'Azure/Entra ID certified'],
  },
  {
    group: 'AI / LLM engineering',
    lead: 'Multi-provider LLM work, from review engines to agentic assistants.',
    tags: ['Anthropic', 'OpenAI', 'Gemini', 'Cohere', 'Mistral', 'DeepSeek', 'multi-pass review engine', 'adversarial LLM verification', 'agentic tool-use (40+ tools)', 'vision LLMs', 'OWL-ViT (local)', 'barcode scanning', 'Open Food Facts', 'Web Speech voice', 'prompt-injection guardrails', 'n8n ops agent'],
  },
  {
    group: 'Application and offensive security',
    lead: 'Authorized practice on TryHackMe and CTFs, plus the OSINT tooling in DeepReview.',
    tags: ['Azure/Entra ID privesc', 'Microsoft Graph', 'Temporary Access Pass', 'SSRF (PDF renderers)', 'stored XSS', 'injection', 'CVE analysis', 'prompt-injection chaining', 'DNS/DNSSEC', 'nmap', 'gobuster', 'hashcat', 'Kali', 'AzureHound', 'Azure CLI', '40+ OSINT collectors', 'subfinder', 'httpx', 'nuclei', 'Tor', 'SearXNG', 'Docker sandbox'],
  },
  {
    group: 'Infrastructure and home lab',
    lead: 'A four-node Proxmox cluster on my own hardware.',
    tags: ['Proxmox', 'Docker', 'Docker Compose', 'LXC', 'Caddy', 'Cloudflare edge', 'Linux', 'Plex', 'Audiobookshelf', 'n8n', 'Ansible', 'restic', 'Wazuh', 'Zabbix', 'Graylog'],
  },
  {
    group: 'Data and cryptography',
    lead: 'Data stores I run, and the crypto and appsec primitives I implemented across the apps.',
    tags: ['Postgres', 'Redis', 'SQLite', 'SQLCipher', 'AES-256-GCM', 'Fernet', 'PBKDF2', 'argon2', 'TOTP', 'WebAuthn', 'HMAC', 'hash-chained audit trails', 'HMAC-signed webhooks', 'SSRF allow-lists', 'prompt-injection fencing', 'security-invariant tests'],
  },
  {
    group: 'Networking',
    lead: 'Home network, plus routing and switching depth backed by Cisco and Juniper certs.',
    tags: ['pfSense (CARP HA)', 'dual-WAN failover', 'fibre + Starlink', 'VLAN segmentation', 'Pi-hole DNS', 'DNSSEC', 'UniFi', 'Cisco lab', 'routing & switching', 'trunking', 'spanning-tree', 'firewalls', 'VPNs'],
  },
  {
    group: 'Electronics and making',
    lead: 'The hardware bench.',
    tags: ['Raspberry Pi 5', 'Hailo-8', 'Pi Pico W', 'ESP32', 'MicroPython', 'MQTT', 'PlutoSDR', 'LibreSDR', 'pH/EC sensors', 'FDM 3D printing'],
  },
];

const writeups = [
  { text: 'Azure / Entra ID privilege escalation: managed identity → Microsoft Graph token → Temporary Access Pass → account takeover', href: '/writeups/tapper-2-azure-tenant' },
  { text: 'Web SSRF through a server-side PDF renderer', href: '/writeups/md2pdf-ssrf' },
  { text: 'AI-pentest room: stored XSS against a reviewer bot, chained with LLM prompt injection', href: '/writeups/medbay-ai-xss-llm' },
  { text: 'AI security: scoping an LLM ops-agent for a Proxmox cluster', href: '/writeups/proxmox-llm-ops-agent' },
  { text: 'Home lab: HA pfSense on Proxmox with dual-WAN failover', href: '/writeups/pfsense-ha-proxmox' },
  { text: 'Home-lab DNS / DNSSEC troubleshooting', href: '/writeups/pihole-dnssec-tcp-fallback' },
];

const hasCredentials =
  CV.certifications.length > 0 || CV.experience.length > 0 || CV.education.length > 0;
---

<Base title="CV" description="Justin White, security practitioner and maker. Skills, writeups, and credentials.">
  <article class="section">
    <div class="wrap wrap-narrow cv">
      <header class="cv-head">
        <h1>Justin White</h1>
        <p class="role">{SITE.tagline}</p>
        <p class="contact">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          {LINKS.github && (<><span>·</span><a href={LINKS.github} rel="me">GitHub</a></>)}
          {LINKS.linkedin && (<><span>·</span><a href={LINKS.linkedin} rel="me">LinkedIn</a></>)}
          {LINKS.tryhackme && (<><span>·</span><a href={LINKS.tryhackme} rel="me">TryHackMe</a></>)}
          {LINKS.credly && (<><span>·</span><a href={LINKS.credly} rel="me">Credly</a></>)}
        </p>
      </header>

      <section>
        <h2>Summary</h2>
        <p>
          I'm accountable for the global security posture of a large, privately held
          multinational: security architecture, governance/risk/compliance, and security
          operations across tens of thousands of people in more than a dozen countries, from
          the industrial front line to corporate IT. I came
          up through network engineering and grew into the role that stood up the cybersecurity
          function, so my bias is toward security an always-on operational business can actually
          live with: controls that hold up to the auditors, insurers, and customers who get a say,
          without stalling production. Most of my career has been bringing security maturity to
          sectors that grew up as industrial operations, not software shops. I stay hands-on, too:
          a self-hosted home lab as a live testbed, and security writeups spanning cloud identity,
          web application, and AI/LLM security.
        </p>
      </section>

      <section>
        <h2>What I lead</h2>
        <p>
          I came up from the network (analyst, then architect) and grew into running the
          whole program. A function this size is never "finished": some of it I've built and
          run for years, some is mid-transformation, some is next on the roadmap. What's
          constant is owning the whole arc: strategy, architecture, governance and risk,
          operations, and the team. The breadth, kept general:
        </p>
        <dl class="skills">
          <div><dt>Security &amp; network architecture</dt><dd>How the whole estate is connected and defended, up to a modern zero-trust edge.</dd></div>
          <div><dt>Detection &amp; response</dt><dd>Seeing threats and acting on them, and leading incident response when something real happens.</dd></div>
          <div><dt>Identity &amp; access</dt><dd>The right people, and only the right people, reaching the right things.</dd></div>
          <div><dt>Resilience</dt><dd>Continuity, disaster recovery, and backup. The half of security that only matters on the worst day.</dd></div>
          <div><dt>Data &amp; software</dt><dd>Protecting the data, and the applications that handle it.</dd></div>
          <div><dt>Governance, risk &amp; compliance</dt><dd>Running the program against recognised frameworks like CIS Controls and NIST CSF, plus third-party and vendor risk.</dd></div>
          <div><dt>Leadership</dt><dd>Building and running the team, owning the budget, and turning technical risk into decisions an executive team and board can make.</dd></div>
        </dl>
        <p class="scope-note">Capabilities and scope only. No tooling, architecture, incidents, or numbers tied to any employer. The detail that sits behind an NDA stays there. How I think about the work in practice is in the <a href="/notes">field notes</a>.</p>
      </section>

      <section>
        <h2>Technologies</h2>
        <p class="scope-note">{techDisclaimer}</p>
        <p class="aside">I bring the ideas, infrastructure, and security. My "phone a friend" brings the code.</p>
        <dl class="skills">
          {technologies.map((s) => (
            <div>
              <dt>{s.group}</dt>
              <dd>
                {s.lead && <p class="grp-lead">{s.lead}</p>}
                {s.projects && (
                  <ul class="proj-list">
                    {s.projects.map((p) => (
                      <li><strong>{p.name}</strong>: {p.desc}</li>
                    ))}
                  </ul>
                )}
                {s.tags && (
                  <p class="tag-line">{s.tags.join(' · ')}</p>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>

      <section>
        <h2>Selected writeups</h2>
        <ul class="links">
          {writeups.map((w) => (<li><a href={w.href}>{w.text}</a></li>))}
        </ul>
      </section>

      <section>
        <h2>Hands-on practice</h2>
        <ul>
          <li>
            <strong>TryHackMe</strong>: offensive-security practice rooms.
            {LINKS.tryhackme && (<> <a href={LINKS.tryhackme} rel="me">View profile →</a></>)}
          </li>
          <li>
            <strong>Home lab</strong>: a four-node Proxmox cluster running an active/passive
            pfSense HA firewall, redundant Pi-hole DNS with DNSSEC, Docker/LXC services, and
            monitoring (Wazuh, Zabbix) as a live environment to test against.
          </li>
          <li>
            <strong>Open source</strong>: public work on
            {LINKS.github ? (<> <a href={LINKS.github} rel="me">GitHub</a>,</>) : (<> GitHub,</>)}
            including this site.
          </li>
        </ul>
      </section>

      {
        hasCredentials && (
          <section>
            <h2>Credentials</h2>
            {CV.certifications.length > 0 && (
              <>
                <h3>Certifications</h3>
                <ul class="cert-badges">
                  {certs.map((c) => (
                    <li>
                      <a href={c.url} rel="me" title={`${c.label}, verified on Credly`}>
                        <img src={c.file} width="80" height="80" loading="lazy" alt={`${c.label}, ${c.issuer}`} />
                        <span>{c.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
                {LINKS.credly && (
                  <p class="verify">
                    <a href={LINKS.credly} rel="me">All certifications, verified on Credly →</a>
                  </p>
                )}
              </>
            )}
            {CV.experience.length > 0 && (
              <>
                <h3>Experience</h3>
                <ul class="exp">
                  {CV.experience.map((e) => (
                    <li>
                      <strong>{e.role}</strong>, {e.org} <span class="period">{e.period}</span>
                      {e.note && <div class="note">{e.note}</div>}
                    </li>
                  ))}
                </ul>
              </>
            )}
            {CV.education.length > 0 && (
              <>
                <h3>Education</h3>
                <ul>{CV.education.map((ed) => (<li>{ed}</li>))}</ul>
              </>
            )}
          </section>
        )
      }
    </div>
  </article>
</Base>

<style>
  .cv section { margin-bottom: 2rem; }
  .cv-head { margin-bottom: 2.25rem; }
  .cv-head h1 { margin: 0; }
  .role { color: var(--ink-muted); margin: 0.2rem 0 0.6rem; font-size: 1.1rem; }
  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.95rem;
    margin: 0;
  }
  .contact span { color: var(--ink-faint); }
  .cv h2 {
    font-size: 1.25rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.9rem;
  }
  .cv h3 { font-size: 1rem; margin: 1.2rem 0 0.4rem; }
  .skills { margin: 0; display: grid; gap: 0.85rem; }
  .skills dt { font-weight: 500; font-family: var(--font-serif); font-size: 1.05rem; }
  .skills dd { margin: 0.15rem 0 0; color: var(--ink-muted); }
  .grp-lead { margin: 0 0 0.55rem; color: var(--ink-muted); line-height: 1.5; }
  .aside { font-style: italic; color: var(--ink-muted); margin: 0 0 1.4rem; line-height: 1.55; }
  .tag-line {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .cv .proj-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.45rem;
  }
  .cv .proj-list li { margin: 0; color: var(--ink-muted); line-height: 1.5; }
  .cv .proj-list strong { color: var(--ink); font-weight: 600; }
  .scope-note {
    background: var(--card-warm);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 0.85rem 1.05rem;
    margin: 0 0 1.4rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-muted);
  }
  .cv ul { padding-left: 1.2rem; margin: 0; }
  .cv li { margin-bottom: 0.5rem; }
  .links a { font-weight: 500; }
  .period { color: var(--ink-faint); font-size: 0.85rem; }
  .note { color: var(--ink-muted); font-size: 0.92rem; margin-top: 0.15rem; }
  .verify { margin-top: 0.6rem; font-size: 0.92rem; }
  .verify a { font-weight: 500; }
  .cert-badges {
    list-style: none;
    padding: 0;
    margin: 0.7rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.25rem, 1fr));
    gap: 1.1rem 0.75rem;
  }
  .cert-badges li { margin: 0; }
  .cert-badges a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    color: var(--ink-muted);
  }
  .cert-badges img { width: 80px; height: 80px; }
  .cert-badges span { font-size: 0.72rem; text-align: center; line-height: 1.25; }
  .cert-badges a:hover span { color: var(--ink); }
</style>

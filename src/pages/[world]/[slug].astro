---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { WORLDS } from '../../consts';
import { getProjects, formatDate, tagHref } from '../../lib/content';

export async function getStaticPaths() {
  const items = await getProjects();
  return items.map((item) => ({
    params: { world: item.data.world, slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { data, entry } = item;
const world = WORLDS[data.world];
const { Content } = await render(entry);
---

<Base title={data.title} description={data.summary} image={`/og/${item.slug}.png`}>
  <article class="section" style={`--accent-w:${world.accent}`}>
    <div class="wrap wrap-narrow">
      <a class="back" href={world.href}>← {world.label}</a>
      <header class="head">
        <span class="world-tag">{world.label}</span>
        <h1>{data.title}</h1>
        <p class="lead">{data.summary}</p>
        <p class="meta">
          <time datetime={data.date.toISOString()}>{formatDate(data.date)}</time>
          {data.tags.length > 0 && data.tags.map((t) => <a class="tag" href={tagHref(t)}>{t}</a>)}
        </p>
      </header>
    </div>

    {
      data.cover && (
        <div class="wrap">
          <Image
            class="cover"
            src={data.cover}
            alt={data.coverAlt ?? data.title}
            width={1280}
            widths={[640, 960, 1280]}
            sizes="(max-width: 64rem) 100vw, 64rem"
          />
        </div>
      )
    }

    <div class="wrap wrap-narrow prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 1.25rem;
  }
  .back:hover { color: var(--accent-w); }
  .world-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    color: #fff;
    background: var(--accent-w);
    padding: 0.2em 0.6em;
    border-radius: 999px;
    margin-bottom: 0.6rem;
  }
  .head h1 { margin: 0 0 0.4rem; }
  .head .lead { margin: 0 0 0.8rem; }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin: 0;
  }
  .meta a.tag { text-decoration: none; color: var(--ink-faint); transition: border-color 0.12s ease, color 0.12s ease; }
  .meta a.tag:hover { border-color: var(--accent-w); color: var(--ink); }
  .cover {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 34rem;
    border-radius: var(--radius-lg);
    margin: 2rem auto;
    border: 1px solid var(--line);
  }
  .prose {
    margin-top: 2rem;
  }
  .prose :global(h2) { margin-top: 2rem; }
  .prose :global(h3) { margin-top: 1.5rem; }
  .prose :global(img) {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 30rem;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    margin: 1.5rem auto;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.3rem;
  }
  .prose :global(li) { margin-bottom: 0.4rem; }
</style>

---
import { SITE, NAV, LINKS } from '../consts';
const year = new Date().getFullYear();

// External profiles, rendered only when set in consts.
const elsewhere = [
  LINKS.linkedin && { label: 'LinkedIn', href: LINKS.linkedin },
  LINKS.github && { label: 'GitHub', href: LINKS.github },
  LINKS.tryhackme && { label: 'TryHackMe', href: LINKS.tryhackme },
  LINKS.credly && { label: 'Credly', href: LINKS.credly },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="site-footer">
  <div class="wrap inner">
    <div class="top">
      <div class="identity">
        <a href="/" class="brand" aria-label={SITE.title}>
          <span class="mark" aria-hidden="true">JW</span>
          <span class="brand-name">{SITE.title}</span>
        </a>
        <p class="muted">{SITE.tagline}</p>
        <a class="email" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>

      <nav class="group explore" aria-label="Site">
        <p class="group-label">Explore</p>
        <ul>
          {NAV.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}
        </ul>
      </nav>

      <div class="group">
        <p class="group-label">Elsewhere</p>
        <ul>
          {elsewhere.map((l) => (<li><a href={l.href} rel="me">{l.label}</a></li>))}
        </ul>
      </div>
    </div>

    <div class="bottom">
      <p class="disclaimer">The opinions here are my own and do not represent my employer.</p>
      <p class="privacy">No cookies, no trackers, no ads. I care about your privacy.</p>
      <p class="copyright">© {year} {SITE.author}. Built with Astro.</p>
      <p class="utility">
        <a href="/uses">Uses</a>
        <a href="/tags">Tags</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    background: var(--paper-2);
    margin-top: 4rem;
  }
  .inner {
    padding-block: 2.75rem 1.75rem;
  }
  .top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2rem 2.5rem;
  }

  .identity .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
  }
  .mark {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.1rem;
  }
  .identity .muted {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin: 0.7rem 0 0;
    max-width: 22rem;
  }
  .identity .email {
    display: inline-block;
    margin-top: 0.55rem;
  }

  .group-label {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .explore ul {
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1.5rem;
  }

  .site-footer a {
    color: var(--ink-muted);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .site-footer a:hover {
    color: var(--ink);
    text-decoration: underline;
  }

  .bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem 1.5rem;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }
  .disclaimer {
    width: 100%;
    margin: 0 0 0.5rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-faint);
  }
  .privacy {
    width: 100%;
    margin: 0 0 0.5rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-muted);
  }
  .copyright {
    margin: 0;
    font-size: 0.82rem;
    color: var(--ink-faint);
  }
  .utility {
    margin: 0;
    display: flex;
    gap: 1.25rem;
  }
  .utility a {
    font-size: 0.82rem;
  }

  @media (max-width: 40rem) {
    .top {
      grid-template-columns: 1fr 1fr;
    }
    .identity {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 24rem) {
    .explore ul {
      grid-template-columns: 1fr;
    }
  }
</style>

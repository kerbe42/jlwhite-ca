---
import { SITE, NAV, LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap inner">
    <div class="cols">
      <div>
        <p class="name">{SITE.title}</p>
        <p class="muted">{SITE.tagline}</p>
      </div>
      <nav aria-label="Footer">
        <ul>
          {NAV.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}
        </ul>
      </nav>
      <div class="links">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        {LINKS.github && <a href={LINKS.github} rel="me">GitHub</a>}
        {LINKS.tryhackme && <a href={LINKS.tryhackme} rel="me">TryHackMe</a>}
      </div>
    </div>
    <p class="copyright">© {year} {SITE.author}. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    background: var(--paper-2);
    margin-top: 4rem;
  }
  .inner {
    padding-block: 2.5rem 2rem;
  }
  .cols {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem 3rem;
    justify-content: space-between;
  }
  .name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin: 0;
  }
  .muted {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin: 0.2rem 0 0;
  }
  nav ul,
  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .site-footer a {
    color: var(--ink-muted);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .site-footer a:hover {
    color: var(--ink);
    text-decoration: underline;
  }
  .copyright {
    margin: 2rem 0 0;
    font-size: 0.82rem;
    color: var(--ink-faint);
  }
</style>

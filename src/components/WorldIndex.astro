---
import ProjectCard from './ProjectCard.astro';
import { WORLDS, type World } from '../consts';
import { getProjects } from '../lib/content';

interface Props {
  world: World;
  note?: string;
}
const { world, note } = Astro.props;
const meta = WORLDS[world];
const items = await getProjects(world);
---

<section class="section" style={`--accent-w:${meta.accent}`}>
  <div class="wrap">
    <header class="head">
      <span class="dot" aria-hidden="true"></span>
      <div>
        <h1>{meta.label}</h1>
        <p class="lead">{meta.blurb}</p>
      </div>
    </header>

    {note && <p class="note">{note}</p>}

    {
      items.length > 0 ? (
        <div class="grid">
          {items.map((item) => (
            <ProjectCard item={item} />
          ))}
        </div>
      ) : (
        <p class="empty">Nothing here yet — projects are being written up. Check back soon.</p>
      )
    }
  </div>
</section>

<style>
  .head {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .head h1 {
    margin: 0;
  }
  .head .lead {
    margin: 0.2rem 0 0;
  }
  .dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 999px;
    background: var(--accent-w);
    margin-top: 0.9rem;
    flex: none;
  }
  .note {
    background: var(--card-warm);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent-w);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    color: var(--ink-muted);
    margin-bottom: 1.75rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1.5rem;
  }
  .empty {
    color: var(--ink-muted);
    padding: 2rem 0;
  }
</style>

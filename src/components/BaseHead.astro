---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { SITE, LINKS } from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: { type?: string; datePublished?: string };
}

const { title, description = SITE.description, image = SITE.ogImage, article } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = image ? new URL(image, Astro.site ?? SITE.url).href : undefined;

const sameAs = [LINKS.linkedin, LINKS.github, LINKS.credly, LINKS.tryhackme].filter(Boolean);
const graph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': `${SITE.url}/#person`,
    name: SITE.author,
    url: SITE.url,
    jobTitle: 'Director, Cybersecurity',
    description: SITE.description,
    sameAs,
  },
  {
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.title,
    description: SITE.description,
    publisher: { '@id': `${SITE.url}/#person` },
  },
];
if (article && title) {
  graph.push({
    '@type': article.type ?? 'Article',
    '@id': `${canonical}#article`,
    headline: title,
    description,
    url: canonical,
    ...(ogImage ? { image: ogImage } : {}),
    ...(article.datePublished ? { datePublished: article.datePublished } : {}),
    author: { '@id': `${SITE.url}/#person` },
    publisher: { '@id': `${SITE.url}/#person` },
    isPartOf: { '@id': `${SITE.url}/#website` },
  });
}
const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t !== 'light' && t !== 'dark') {
        t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.dataset.theme = t;
    } catch (e) {}
  })();
</script>
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="generator" content={Astro.generator} />

<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />

<meta name="theme-color" content="#fbf7ef" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
<script type="application/ld+json" is:inline set:html={jsonLd} />
